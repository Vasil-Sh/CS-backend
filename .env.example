# ============================================
# MatchIQ Backend — Environment Variables
# Copy to .env and fill in values
# ============================================

# ── Server ──
PORT=3001
NODE_ENV=development

# ── PostgreSQL ──
DATABASE_URL=postgresql://matchiq:matchiq@localhost:5432/matchiq

# ── JWT ──
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string
JWT_REFRESH_EXPIRES_IN=30d

# ── DeepSeek AI ──
DEEPSEEK_API_KEY=

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ── CS2 Match API ──
CS_API_URL=https://api.cstest.pp.ua

# ── Google Sheets (read-only, for legacy data import) ──
GOOGLE_SHEETS_API_KEY=

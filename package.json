{
  "name": "matchiq-backend",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "npx tsx src/index.ts",
    "build": "tsc",
    "start": "npx tsx src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "npx tsx src/db/seed.ts",
    "db:seed-prod": "npx tsx src/db/seed.ts",
    "db:import-users": "npx tsx src/db/migrateUsers.ts",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "npx tsx src/db/runMigrations.ts",
    "lint": "eslint --quiet ./src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.6.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0",
    "tsx": "^4.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}

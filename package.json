{
  "name": "matchiq-backend",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "npx tsx src/index.ts",
    "build": "tsc",
    "start": "npx tsx src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "npx tsx src/db/seed.ts",
    "db:seed-prod": "npx tsx src/db/seed.ts",
    "db:import-users": "npx tsx src/db/migrateUsers.ts",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "npx tsx src/db/runMigrations.ts",
    "db:migrate-constraints": "npx tsx src/db/migrateConstraints.ts",
    "lint": "eslint --quiet ./src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=999",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hono/node-server": "^1.13.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.6.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0",
    "tsx": "^4.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.28.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
